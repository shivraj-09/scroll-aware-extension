{
  "manifest_version": 3,
  "name": "ScrollAware",
  "description": "Detects continuous scrolling on social media and nudges users to take mindful breaks.",
  "version": "0.1.0",

  "icons": {
    "128": "icons/icon128.png"
  },

  "permissions": [
    "storage",
    "notifications"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": [
        "*://*.instagram.com/*",
        "*://*.tiktok.com/*"
      ],
      "js": ["content.js"]
    }
  ]
}
